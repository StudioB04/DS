{
  "name": "@studio_b04/ds",
  "description": "StudioB04 Design System",
  "version": "0.1.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "dist/components.js",
  "module": "./dist/components.js",
  "types": "dist/components/index.d.ts",
  "exports": {
    "./uikit": {
      "import": "./dist/components/uikit.js",
      "types": "./dist/components/uikit.d.ts"
    },
    "./styles": "./dist/styles.css",
    "./reset": "./dist/reset.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "husky || true",
    "start": "storybook dev -p 6006",
    "cleanup": "rm -rf ./dist",
    "build": "npm run cleanup && vite build",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --check \"./src/**/*.{tsx,ts}\"",
    "prettier:fix": "prettier --write \"./src/**/*.{tsx,ts}\"",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@storybook/addon-a11y": "^10.0.0",
    "@storybook/addon-docs": "^10.0.0",
    "@storybook/react-vite": "^10.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "clsx": "^2.1.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-sonarjs": "^4.0.3",
    "globals": "^15.0.0",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "prettier": "^3.8.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "storybook": "^10.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vite-plugin-lib-inject-css": "^2.0.0",
    "vite-tsconfig-paths": "^5.0.0",
    "vitest": "^4.0.0",
    "vitest-axe": "^0.1.0"
  },
  "dependencies": {
    "lucide-static": "^1.16.0",
    "markdown-to-jsx": "^9.8.2"
  }
}
